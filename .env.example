# --- Public host: how Twilio reaches this server (host only, no scheme) ---
# Local dev: run `ngrok http 8080` and use the forwarding host.
PUBLIC_URL=your-subdomain.ngrok.io

# Shared secret the Apps Script sends in X-Lead-Secret. Must match apps_script.gs.
LEAD_SHARED_SECRET=generate-a-long-random-string

# --- Twilio ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+15551234567

# --- Google Sheets ---
# Path to the service-account JSON key file. Share the sheet with the key's
# client_email (Editor). Keep this file out of git.
GOOGLE_SERVICE_ACCOUNT_JSON=./service_account.json
SHEET_ID=your-google-sheet-id
SHEET_TAB=Sheet1

# --- STT: AssemblyAI ---
ASSEMBLYAI_API_KEY=your-assemblyai-key

# --- LLM: Anthropic ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
LLM_MODEL=claude-haiku-4-5

# --- TTS: Cartesia ---
CARTESIA_API_KEY=your-cartesia-key
CARTESIA_VOICE_ID=your-cartesia-voice-id
CARTESIA_MODEL=sonic-2

# --- Server ---
HOST=0.0.0.0
PORT=8080
